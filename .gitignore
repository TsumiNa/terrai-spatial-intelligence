.venv/
__pycache__/
*.py[cod]
.DS_Store

# Svelte webapp toolchain
node_modules/
webapp/dist/
webapp/playwright-report/
webapp/test-results/

# TEPCO source files are publicly readable but marked redistribution-prohibited.
# Keep them only in the local working copy; commit the documented screening result.
data/external/tepco/*.zip
data/external/tepco/*.csv
data/external/tepco/*.local.json

# PLATEAU source archives and expanded 3D Tiles are reproducible on-demand
# caches. Commit the selection, retrieval manifest and lightweight audit index,
# not the upstream binaries.
data/external/plateau_uc24_16/
data/external/plateau_uc24_13/

# The spatially indexed store is derived from the committed datasets and
# rebuilt by ensure_data; a binary that diffs as a full rewrite on every
# refresh must never enter git.
var/
