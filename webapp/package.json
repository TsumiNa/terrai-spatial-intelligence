{
  "name": "terrai-webapp",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "svelte-check --tsconfig ./tsconfig.json && vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "generate:api": "uv run --directory .. python webapp/scripts/export_openapi.py && openapi-typescript openapi.json -o src/lib/api/schema.d.ts"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@internationalized/date": "3.12.2",
    "@playwright/test": "^1.61.1",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@tailwindcss/vite": "^4.3.3",
    "@tsconfig/svelte": "^5.0.8",
    "@types/three": "^0.185.1",
    "bits-ui": "2.18.1",
    "openapi-typescript": "^7.13.0",
    "svelte": "^5.56.7",
    "svelte-check": "^4.7.3",
    "tailwindcss": "^4.3.3",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@deck.gl/core": "^9.3.7",
    "@deck.gl/extensions": "^9.3.7",
    "@deck.gl/geo-layers": "^9.3.7",
    "@deck.gl/layers": "^9.3.7",
    "@deck.gl/mapbox": "^9.3.7",
    "3d-tiles-renderer": "^0.5.0",
    "maplibre-gl": "^6.0.0",
    "openapi-fetch": "^0.17.0",
    "three": "^0.185.1"
  }
}
