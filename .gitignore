.venv/
__pycache__/
*.py[cod]
.DS_Store

# Svelte webapp toolchain
node_modules/
webapp/dist/
webapp/playwright-report/
webapp/test-results/

# TEPCO source files are publicly readable but marked redistribution-prohibited.
# Keep them only in the local working copy; commit the documented screening result.
data/external/tepco/*.zip
data/external/tepco/*.csv
data/external/tepco/*.local.json

# PLATEAU source archives and expanded 3D Tiles are reproducible on-demand
# caches. Commit the selection, retrieval manifest and lightweight audit index,
# not the upstream binaries.
data/external/plateau_uc24_16/
data/external/plateau_uc24_13/

# The spatially indexed store is derived from the committed datasets and
# rebuilt by ensure_data; a binary that diffs as a full rewrite on every
# refresh must never enter git.
var/

# The MLIT foundation data is a reproducible acquisition at the Kanto window
# (fetch mlit), provisioned by ensure_data locally and by the Actions cache in
# CI. Gigabyte-scale products never enter git.
data/mlit/

# The OSM Kanto building footprints share the same reproducible-acquisition
# treatment (fetch osm_kanto).
data/osm/kanto_buildings/

# The 基盤地図情報 (FGD) Kanto building outlines are a registration-gated manual
# acquisition (fetch fgd_kanto): the raw GML archive and the gigabyte-scale
# normalized product stay out of git; the small source_manifest.json and the
# generated metadata.json manifest are committed.
data/fgd/kanto_buildings/source/
data/fgd/kanto_buildings/buildings.geojson

# The merged building tile source (fetch merged_tiles): the line-delimited merge
# and the generated PMTiles are gigabyte-scale build products; the manifest is
# committed. buildings.geojson-style products are regenerable from the pinned
# OSM + FGD acquisitions.
data/tiles/kanto_buildings/merged.geojsonl
data/tiles/kanto_buildings/buildings.pmtiles
